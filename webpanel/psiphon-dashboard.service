[Unit]
Description=Psiphon Panel Web Dashboard
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/psiphon-dashboard
EnvironmentFile=/etc/psiphon-dashboard.env
ExecStart=/opt/psiphon-dashboard/venv/bin/gunicorn -w 2 -b 127.0.0.1:8088 --timeout 90 app:app
Restart=on-failure
RestartSec=3

[Install]
WantedBy=multi-user.target
